HOST=0.0.0.0
PORT=8787
VERITE_MEDIA_AI=1
VERITE_MEDIA_AI_URL=http://127.0.0.1:8790/analyze
VERITE_MEDIA_AI_PORT=8790
VERITE_AI_COMMITTEE=0
VERITE_AI_API_KEY=
VERITE_AI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
VERITE_AI_MODEL=qwen3-coder-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional paid / official search APIs.
# Leave blank to keep using the built-in public connectors.
BING_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
NEWSAPI_KEY=
TAVILY_API_KEY=
WIKIMEDIA_API_TOKEN=

# Google News RSS is enabled by default as a discovery connector.
# Set to 0 to disable it if your hosting network is throttled or blocked.
VERITE_GOOGLE_NEWS_RSS=1
VERITE_GOOGLE_NEWS_CACHE_TTL_MS=900000
VERITE_GOOGLE_NEWS_MAX_PER_STAGE=2
VERITE_GOOGLE_NEWS_RSS_TIMEOUT_MS=6500
VERITE_GOOGLE_NEWS_RESOLVE_TIMEOUT_MS=3000

# Public search connectors that return 403/429 are temporarily skipped for this duration.
VERITE_CONNECTOR_BACKOFF_MS=60000

# Basic API protection.
VERITE_MAX_JSON_BODY_BYTES=102400
VERITE_RATE_LIMIT_WINDOW_MS=60000
VERITE_RATE_LIMIT_MAX=60
